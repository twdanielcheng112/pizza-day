# Godot 4+ specific ignores
.godot/
/android/

# M1 — platform-specific compiled binary, built locally via `make` in c_src/
/maze_core
/maze_core.exe

# M1 — runtime output (Godot user:// dir is platform-specific; this match is
# defensive in case maze_core is ever run with a project-relative argv[1])
/maze_state.json

# Claude Code — per-developer local settings (do not commit)
.claude/settings.local.json

# Dev-only scratch scenes (sprite previews, isolation tests, etc.)
/scenes/dev/
